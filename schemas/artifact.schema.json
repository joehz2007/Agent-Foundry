{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/agent-foundry/artifact.schema.json",
  "title": "Agent Foundry Artifact",
  "type": "object",
  "required": ["id", "type", "title", "version", "description", "instructions"],
  "additionalProperties": true,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "type": {
      "type": "string",
      "enum": ["agent", "skill", "command"]
    },
    "title": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 20},
    "triggers": {
      "type": "array",
      "items": {"type": "string"}
    },
    "targets": {
      "type": "array",
      "items": {"type": "string", "enum": ["claude-code", "codex", "pi"]}
    },
    "inputs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "outputs": {
      "type": "object",
      "properties": {
        "format": {"type": "string"},
        "sections": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "instructions": {"type": "string", "minLength": 1},
    "resources": {
      "type": "object",
      "properties": {
        "references": {
          "type": "array",
          "items": {"type": "string"}
        },
        "scripts": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "platforms": {"type": "object"},
    "evals": {
      "type": "array",
      "items": {"type": "string"}
    },
    "changelog": {
      "type": "array",
      "items": {"type": "object"}
    }
  }
}
